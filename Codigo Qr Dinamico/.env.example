# ==========================================
# CONFIGURACIÓN GENERAL (main_dynamic.py)
# ==========================================
# Las conexiones a SQL Server YA NO van aquí: se administran desde la
# aplicación (botón "Nueva conexión") y se guardan en db_connections.json.
# Las contraseñas se guardan en el Administrador de credenciales de Windows.
# Este archivo es opcional: todos los valores tienen un default razonable.

# Rutas de los archivos de configuración (relativas al directorio de trabajo)
CONNECTIONS_FILE=db_connections.json
QUERIES_FILE=queries_config.json

# Nivel de logging para app.log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Límite máximo de filas por consulta (protección del lado de la app)
MAX_ROWS=500
